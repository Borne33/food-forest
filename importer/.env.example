# ─────────────────────────────────────────────────────────────────
#  Food Forest importer — configuration TEMPLATE.
#  Copy this file to `.env` (same folder) and fill in the values.
#  `.env` is gitignored and must NEVER be committed.
# ─────────────────────────────────────────────────────────────────

# Supabase — Dashboard ▸ Project Settings ▸ API
SUPABASE_URL=https://sysrtpvnkpfuieznfkzb.supabase.co
# The SECRET service_role key (NOT the anon/publishable key).
# Needed to write to the RLS-protected `plants` table from a script.
SUPABASE_SERVICE_ROLE_KEY=

# ── LLM drafting step (choose ONE, or leave all blank for Route A) ──
# Route A (default, free): leave both blank. The importer emits research
#   packets you paste into your Claude chat; Claude drafts the JSON.
# Route B (free, automated): put a Google Gemini key here.
GEMINI_API_KEY=
# Route C (paid, automated): put an Anthropic key here.
ANTHROPIC_API_KEY=
